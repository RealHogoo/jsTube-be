APP_ENV=dev
MEDIA_SERVICE_PORT=8084
MEDIA_SERVICE_SECRET_KEY=dev-media-secret
MEDIA_SERVICE_DEBUG=true
MEDIA_SERVICE_ALLOWED_HOSTS=localhost,127.0.0.1
MEDIA_SERVICE_CORS_ORIGINS=http://localhost:5174,http://localhost:8084,http://localhost:8085,http://127.0.0.1:8084,http://127.0.0.1:8085

ADMIN_SERVICE_BASE_URL=http://localhost:8081
ADMIN_INTERNAL_API_TOKEN=dev-media-internal-token
WEBHARD_PUBLIC_BASE_URL=http://localhost:8083
WEBHARD_INTERNAL_BASE_URL=http://localhost:8083
MEDIA_INTERNAL_API_TOKEN=dev-media-internal-token

MEDIA_MONGO_URI=mongodb://localhost:27017
MEDIA_MONGO_DATABASE=media_service
MEDIA_SYNC_LIMIT=500
MEDIA_SERVICE_STATUS_CACHE_SECONDS=5
MEDIA_FILE_TOKEN_SECONDS=7200
YOUTUBE_IMPORT_LIMIT=100
YOUTUBE_IMPORT_MAX_ITEMS=100
YOUTUBE_AUTO_INSTALL_FFMPEG=true
